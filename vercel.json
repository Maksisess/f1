{
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/wallet-cron",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "api/wallet-cron.js": {
      "maxDuration": 60
    },
    "api/user.js": {
      "maxDuration": 60
    },
    "api/roulette.js": {
      "maxDuration": 30
    },
    "api/bot.js": {
      "maxDuration": 30
    }
  }
}
